# Avenger Gym — production environment (copy to .env and fill in)

DATABASE_URL="file:./dev.db"

# NextAuth (required for /admin)
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"
# Dev-only plain password (remove in production). Easiest way to log in locally.
ADMIN_PASSWORD="change-me"
# Optional production: bcrypt hash. Use single quotes — $ is special in .env.
# ADMIN_PASSWORD_HASH='$2b$10$...'

# Admin notifications (optional)
ADMIN_NOTIFY_EMAIL="ops@example.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Telegram (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Razorpay (required for card/UPI/netbanking/wallets)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# NOWPayments — crypto invoice (optional)
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# Public site URL for webhooks and redirects (production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Social links (footer, trainers)
NEXT_PUBLIC_SOCIAL_INSTAGRAM="https://www.instagram.com/"
NEXT_PUBLIC_SOCIAL_TWITTER="https://twitter.com/"
NEXT_PUBLIC_SOCIAL_LINKEDIN="https://www.linkedin.com/"
NEXT_PUBLIC_SOCIAL_YOUTUBE="https://www.youtube.com/"
NEXT_PUBLIC_SOCIAL_FACEBOOK="https://www.facebook.com/"
